# Apache .htaccess untuk RekapBNP WiFi API
# Mengaktifkan CORS dan URL routing

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /rekapwifi-api/
</IfModule>

# Sembunyikan file sensitif
<FilesMatch "(^\.htaccess|database\.php|\.env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
